# Copy to .env.production / .env.development locally. Do NOT commit real values.
# VITE_* are baked in at `npm run build` time.

# Panel API origin (empty = same-origin /api/v1)
# VITE_API_BASE=https://www.example.com

# Crisp Website ID — your own account only. Leave empty to disable chat.
# VITE_CRISP_WEBSITE_ID=
